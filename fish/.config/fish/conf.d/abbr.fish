# Abbreviations ported from .zshrc aliases

# shell
abbr --add reload 'exec fish'
abbr --add x 'clear'

# ls
abbr --add ls 'ls -hG'
abbr --add l 'ls -ahG'
abbr --add ll 'ls -lahG'

# navigation
abbr --add j jump

# git
abbr --add g git

# python
abbr --add python python3
abbr --add pip pip3
abbr --add pyvc 'python3 -m venv .venv/'
abbr --add pyva 'source .venv/bin/activate.fish'

# bun
abbr --add b bun

# supabase
abbr --add sb supabase
