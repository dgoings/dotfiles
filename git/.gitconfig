[user]
	name = Dylan Goings
	email = dylan@dgoings.com
[mergetool]
	keepBackup = true
[alias]
	a = add
	aa = add .
	st = status
	ci = commit -m
	ca = commit --amend --no-edit
	co = checkout
	tb = git checkout --track
	br = branch
	lg = log --graph --all --topo-order --pretty='format:%h %ai %s%d (%an)'
	pgl = "!source ~/.githelpers && pretty_git_log"
	pbr = "!source ~/.githelpers && pretty_git_branches"
	pu = push
	pl = pull
	irb = !git rebase -i origin/main
	mgff = merge --ff-only
	fe = fetch
	up = !git fetch origin && git rebase origin/master
	cleanup = !git remote prune origin && git gc && git clean -dfx && git stash clear
	df = diff --color
[credential]
	helper = osxkeychain
[push]
	default = simple
	autoSetupRemote = true
[pull]
	default = rebase
	rebase = true
[merge]
	conflictstyle = zdiff3
[rebase]
	autoStash = true
	autoSquash = true
[init]
	defaultBranch = main
[core]
	excludesfile = $HOME/.gitignore_global
